[Unit]
Description=ABERP-site SvelteKit Node server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=aberp
Group=aberp
WorkingDirectory=/home/aberp/current
# Default to a 50 MB request-body cap so adapter-node's stock 512 KB limit does
# not silently 413 every CAD upload. EnvironmentFile values override this if the
# operator sets BODY_SIZE_LIMIT explicitly in /etc/aberp-site.env.
Environment=BODY_SIZE_LIMIT=52428800
EnvironmentFile=/etc/aberp-site.env
ExecStart=/usr/bin/node build
Restart=on-failure
RestartSec=5
# Logs land in append-mode files; logrotate (configured by lightsail-bootstrap.sh)
# rotates them daily, keeps 14 days, compressed.
StandardOutput=append:/home/aberp/logs/aberp-site.log
StandardError=append:/home/aberp/logs/aberp-site.err

# Hardening — the Node process only needs to read its release dir and write to
# /home/aberp/{logs,data}. The data symlink resolves to /mnt/aberp-data, which
# must be explicitly granted in ReadWritePaths.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
ReadWritePaths=/home/aberp/logs /home/aberp/data /mnt/aberp-data

[Install]
WantedBy=multi-user.target
