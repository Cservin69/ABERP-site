# Local-dev defaults. Copy to .env (gitignored) and edit, or export inline:
#   export $(grep -v '^#' .env.example | xargs) && npm run dev

# Admin bearer-token / cookie value. Production: openssl rand -hex 32.
ABERP_SITE_ADMIN_TOKEN=dev-only-local-token

# Where multipart uploads land. Production: /home/aberp/data/quotes.
ABERP_SITE_QUOTE_DIR=./data/quotes

# 50 MB cap matching MAX_TOTAL_BYTES in src/routes/api/quote/+server.ts.
# adapter-node defaults to 512 KB which silently 413s every CAD upload.
BODY_SIZE_LIMIT=52428800

# Optional in dev. Production set on the Lightsail box only.
# CLOUDFRONT_SHARED_SECRET=

# --- Public origin (PR-Q) ------------------------------------------------
# Single source of truth for the public-facing base URL of this deployment.
# Read at runtime by src/lib/server/public-url.ts; consumed by:
#   - operator + customer transactional emails (admin deep-link, signed /q link)
#   - dynamic sitemap.xml + robots.txt
#   - canonical / og:url / og:image meta tags rendered in +layout.svelte
#   - Origin allowlist for state-changing endpoints (src/lib/server/origin-check.ts)
# Default if unset: https://abenerp.com. Pin explicitly on staging boxes so they
# never advertise prod links. Reconciles the legacy ABERP_SITE_PUBLIC_BASE_URL
# variant from PR-L — only this name is honoured now.
# ABERP_SITE_PUBLIC_URL=https://abenerp.com

# SvelteKit's standard ORIGIN env: pins the request origin SvelteKit reconstructs
# behind a reverse proxy. Production sets ORIGIN to the public URL so the
# built-in csrf.checkOrigin matches the browser's Origin header. In dev the
# vite-served default works without setting this.
# ORIGIN=https://abenerp.com

# --- Transactional email (quote notifications) ---------------------------
# SERVER-ONLY. All read via $env/dynamic/private; never bundled to the client.
# Leave unset in dev: email send becomes a silent no-op and quote submission
# still succeeds. Configure on the Lightsail box only.
#
# Minimum config to enable sending: SMTP_HOST + SMTP_USER + SMTP_PASS + SMTP_FROM.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                       # default 587 (STARTTLS); use 465 with SMTP_SECURE=true
# SMTP_SECURE=false                   # true = implicit TLS (port 465)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ABENERP <quotes@abenerp.com>
# Where operator "new quote" notifications land. Defaults to SMTP_FROM if unset.
# ABERP_SITE_OPERATOR_EMAIL=quotes@abenerp.com

# --- Customer quote-status page (PR-L) -----------------------------------
# HMAC key signing the customer quote-status links (/q/<id>?t=<token>).
# Production: openssl rand -hex 32. Rotating it invalidates every issued link.
QUOTE_STATUS_SIGNING_KEY=dev-only-local-quote-signing-key
