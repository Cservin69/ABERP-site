# Local-dev defaults. Copy to .env (gitignored) and edit, or export inline:
#   export $(grep -v '^#' .env.example | xargs) && npm run dev

# Admin bearer-token / cookie value. Production: openssl rand -hex 32.
ABERP_SITE_ADMIN_TOKEN=dev-only-local-token

# Where multipart uploads land. Production: /home/aberp/data/quotes.
ABERP_SITE_QUOTE_DIR=./data/quotes

# 50 MB cap matching MAX_TOTAL_BYTES in src/routes/api/quote/+server.ts.
# adapter-node defaults to 512 KB which silently 413s every CAD upload.
BODY_SIZE_LIMIT=52428800

# Optional in dev. Production set on the Lightsail box only.
# CLOUDFRONT_SHARED_SECRET=
