# Local-dev defaults. Copy to .env (gitignored) and edit, or export inline:
#   export $(grep -v '^#' .env.example | xargs) && npm run dev

# Admin bearer-token / cookie value. Production: openssl rand -hex 32.
ABERP_SITE_ADMIN_TOKEN=dev-only-local-token

# Where multipart uploads land. Production: /home/aberp/data/quotes.
ABERP_SITE_QUOTE_DIR=./data/quotes

# adapter-node parses BODY_SIZE_LIMIT at server startup and 413s any request
# above it BEFORE the SvelteKit handler runs — so the in-handler size caps
# can't defend against a too-low value. 50 MB covers the two endpoints that
# carry large bodies:
#   - POST /api/quote                MAX_TOTAL_BYTES = 50 MB (customer CAD upload)
#   - POST /api/quotes/{id}/priced   BODY_MAX_BYTES  =  6 MB (ABERP priced writeback, ADR-0004)
# The adapter-node default (512 KB) silently 413s every CAD upload and every
# priced PDF over half a meg. S285 review F1 documented the failure in detail;
# hooks.server.ts warns on boot if this value falls below 50 MB. Do NOT drop
# this to 6 MB to "match" ADR-0004 — that breaks /api/quote.
BODY_SIZE_LIMIT=52428800

# Optional in dev. Production set on the Lightsail box only.
# CLOUDFRONT_SHARED_SECRET=

# --- Public origin (PR-Q) ------------------------------------------------
# REQUIRED in production. Single source of truth for the public-facing base
# URL of this deployment. Read at runtime by src/lib/server/public-url.ts;
# consumed by:
#   - operator + customer transactional emails (admin deep-link, signed /q link)
#   - dynamic sitemap.xml + robots.txt
#   - canonical / og:url / og:image meta tags rendered in +layout.svelte
#   - Origin allowlist for state-changing endpoints (src/lib/server/origin-check.ts)
#
# PR-R makes publicSiteUrl() throw on first call in production (`!dev` and
# not `building`) when this var is unset/blank. Dev + build/prerender keep
# falling back to https://abenerp.com so local tooling and CI builds work.
# Pin this on every deployed host — a staging box without it will refuse
# every state-changing POST instead of fail-opening with the prod URL.
# Reconciles the legacy ABERP_SITE_PUBLIC_BASE_URL variant from PR-L — only
# this name is honoured now.
# ABERP_SITE_PUBLIC_URL=https://abenerp.com

# SvelteKit's standard ORIGIN env: pins the request origin SvelteKit reconstructs
# behind a reverse proxy. Production sets ORIGIN to the public URL so the
# built-in csrf.checkOrigin matches the browser's Origin header. In dev the
# vite-served default works without setting this.
# ORIGIN=https://abenerp.com

# --- Transactional email (quote notifications) ---------------------------
# SERVER-ONLY. All read via $env/dynamic/private; never bundled to the client.
# Leave unset in dev: email send becomes a silent no-op and quote submission
# still succeeds. Configure on the Lightsail box only.
#
# PR-04 / ADR-0007: outbound customer mail now relays through ABERP's
# /api/internal/send-email endpoint instead of direct SMTP. The storefront no
# longer holds SMTP credentials; one sender identity, one SPF/DKIM lineage,
# one audit ledger on the ABERP side. See docs/adr/0007 for the wire contract.
#
# Minimum config to enable sending:
#   ABERP_INTERNAL_BASE_URL  + ABERP_EMAIL_RELAY_TOKEN + ABERP_SITE_OPERATOR_EMAIL.
#
# ABERP's base URL for internal-only callers. Production: the ABERP TLS
# endpoint that already terminates quote-intake traffic. Dev default below
# points at the local ABERP harness on 127.0.0.1:8080.
# ABERP_INTERNAL_BASE_URL=http://127.0.0.1:8080
#
# Bearer token authenticating the relay endpoint. DEDICATED — must NOT be the
# same value as ABERP_QUOTE_INTAKE_TOKEN so the two surfaces rotate independently
# (a compromised email-relay token does not grant quote-intake access).
# Production: openssl rand -hex 32 on ABERP, paste here on the storefront.
# ABERP_EMAIL_RELAY_TOKEN=
#
# Where operator "new quote" notifications land. REQUIRED — there is no
# SMTP_FROM fallback any more (PR-04 / ADR-0007 made the storefront strictly
# a "to/cc" caller; the relay decides the canonical "from" identity).
# ABERP_SITE_OPERATOR_EMAIL=quotes@abenerp.com
#
# --- Deprecated SMTP_* vars (PR-04 / ADR-0007) ---------------------------
# The storefront's email helper no longer reads SMTP_HOST/PORT/SECURE/USER/PASS/FROM.
# They linger in /etc/aberp-site.env until the operator removes them; the code
# path that used them is gone. Slated for removal one or two clean deploys after
# PR-04 ships. Do NOT add new code that reads them.

# --- Customer quote-status page (PR-L) -----------------------------------
# HMAC key signing the customer quote-status links (/q/<id>?t=<token>) AND
# the PR-04 accept link (/q/<id>/accept?ts=&sig=). Domain separation in the
# HMAC input (`"status"` vs `"accept"` strings) prevents a status signature
# from being replayed as an accept signature even under the same key — see
# ADR-0005 §"Why two domains in the HMAC input." One secret = one rotation
# surface for both surfaces.
# Production: openssl rand -hex 32. Rotating it invalidates every issued link
# (both status and accept) at once — the global kill switch.
QUOTE_STATUS_SIGNING_KEY=dev-only-local-quote-signing-key
